{
  "name": "glyphsmith",
  "version": "0.1.1",
  "description": "Agent-native SVG editor powered by Geometry AST and patch-based editing.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "glyphsmith": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.ja.md",
    "LICENSE",
    "skills",
    "web"
  ],
  "keywords": [
    "svg",
    "editor",
    "geometry",
    "mcp",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KobayashiRui/GlyphSmith.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/KobayashiRui/GlyphSmith/issues"
  },
  "homepage": "https://github.com/KobayashiRui/GlyphSmith#readme",
  "scripts": {
    "build": "node ../../scripts/build-cli.mjs",
    "check-types": "tsc --noEmit",
    "dev": "pnpm run build && node dist/index.js host --example playground",
    "dev:icons": "pnpm run build && node dist/index.js host --example glyphsmith",
    "prepack": "pnpm -w run build:cli"
  },
  "devDependencies": {
    "@glyphsmith/ast": "workspace:*",
    "@glyphsmith/mcp": "workspace:*",
    "@glyphsmith/svg": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22",
    "hono": "^4.12.23",
    "typescript": "5.9.2"
  }
}
