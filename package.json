{
  "name": "glyph-smith",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=web --filter=glyphsmith",
    "dev:icons": "turbo run dev:icons --filter=web --filter=glyphsmith",
    "export:icons": "pnpm --filter glyphsmith run build && node apps/cli/dist/index.js export --example glyphsmith --out apps/web/static/icons --clean",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
